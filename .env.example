PORT=5050
DATABASE_URL=postgres://user:pass@localhost:5432/siamepos_spa
JWT_SECRET=replace-with-long-random-hex-string
BREVO_API_KEY=
ANTHROPIC_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TREATWELL_WEBHOOK_SECRET=
# UNSUB_SECRET signs the HMAC tokens in campaign unsubscribe links.
# Generate with: openssl rand -hex 32  (or any long random string).
# MUST be set in production — if unset (or left at the old committed
# default), the app falls back to a RANDOM per-boot secret so tokens
# can't be forged, but existing unsubscribe links break on every restart.
UNSUB_SECRET=replace-with-long-random-hex-string
# BOOKING_SECRET signs the HMAC tokens in customer manage-link / booking
# tokens (read / reschedule / cancel an appointment).
# Generate with: openssl rand -hex 32  (or any long random string).
# MUST be set in production — if unset (or left at the old committed
# default), the app falls back to a RANDOM per-boot secret so tokens
# can't be forged, but existing manage links break on every restart.
BOOKING_SECRET=replace-with-long-random-hex-string
# SPA_ADDRESS appears in the GDPR footer of campaign emails.
SPA_ADDRESS=
SPA_NAME=SiamEPOS Spa
SPA_EMAIL=info@siamepos.co.uk
PUBLIC_API_URL=http://localhost:5050
# Optional Brevo key — without it, campaign sends return a clear 500
BREVO_API_KEY=

# ─── Gift-voucher wallet passes (SPA-WALLET-001) ──────────────────────
# Both are OPTIONAL. Leave blank and the "Add to Wallet" buttons simply
# don't appear and the endpoints return 503 — nothing else breaks.
#
# Apple Wallet — reuse the SAME values already set on the restaurant-epos
# Railway service (the spa shares that Apple pass type + signing cert).
#   Export the signer .p12, then:
#     PASS_SIGNER_CERT_B64 = base64 of the signer certificate PEM
#     PASS_SIGNER_KEY_B64  = base64 of the encrypted signer key PEM
#     PASS_SIGNER_KEY_PASSPHRASE = the .p12 export passphrase
PASS_SIGNER_CERT_B64=
PASS_SIGNER_KEY_B64=
PASS_SIGNER_KEY_PASSPHRASE=
#
# Google Wallet — new. Create a Google Cloud project, enable the Google
# Wallet API, make a Wallet Issuer account, and a service account key.
#   GOOGLE_WALLET_ISSUER_ID  = numeric issuer id from the Wallet console
#   GOOGLE_WALLET_SA_EMAIL   = the service account's email
#   GOOGLE_WALLET_SA_KEY_B64 = base64 of the SA private-key PEM
#                              (base64 the "private_key" from the SA JSON so
#                               its newlines survive the Railway env editor)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_EMAIL=
GOOGLE_WALLET_SA_KEY_B64=

# ─── WhatsApp AI concierge (SPA-WHATSAPP-AI-001) ──────────────────────
# ANTHROPIC_API_KEY powers the concierge (and the Treatwell AI extractor).
ANTHROPIC_API_KEY=
# Model for the concierge tool-use loop (defaults to a current Sonnet).
CONCIERGE_MODEL=claude-sonnet-5
# How long a chat-held slot is reserved before it auto-releases (minutes).
CONCIERGE_HOLD_TTL_MIN=15
# Shared secret that gates the /api/concierge/* HTTP tools. Leave BLANK to keep
# that HTTP surface disabled (the Stage-2 orchestrator calls the tools in-process
# and doesn't need it). Set a long random value only if you drive the tools from
# an external prototype (e.g. Make.com). Generate: openssl rand -hex 32
CONCIERGE_SECRET=
# Stage 2 (orchestrator) — Twilio WhatsApp. Filled in once the WhatsApp Business
# number is approved. Left here so the deploy checklist is complete.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_INBOUND_SECRET=
